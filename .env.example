# =================================================================
# ACCTKD · Variables de entorno
# Copia este archivo a .env.local y completa los valores
# =================================================================

# Supabase — proyecto en la nube (Vercel / producción)
# Settings → API → Project URL / anon public key
NEXT_PUBLIC_SUPABASE_URL=https://XXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Desarrollo local (Docker + `supabase start`) ---
# Sustituye por la salida de `supabase status` (API URL y anon key).
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi... (clave anon local, no la de producción)

# Service role (solo servidor · API inscripción / cron). Nunca expongas en el cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Cron backup campeonatos (Vercel Cron → /api/cron/backup-campeonato)
CRON_SECRET=genera-un-secreto-largo-aqui

# Branding
NEXT_PUBLIC_APP_NAME=ACCTKD · Administración
# URL pública de producción (no uses enlaces *-projects.vercel.app)
NEXT_PUBLIC_APP_URL=https://acctkd-administracion-an52.vercel.app
NEXT_PUBLIC_ACADEMIA_NOMBRE=Christopher Cabrera Tae Kwon Do
